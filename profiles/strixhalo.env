# Machine profile: AMD Strix Halo / Ryzen AI Max+ 395 (gfx1151, Radeon 8060S, unified memory)
#
# Sourced by the runtime launchers (runtime/rocm/run-rocm.sh, runtime/vulkan/run-vulkan.sh)
# when MACHINE=strixhalo. Every value here is a shell-level default: it only takes effect
# if the variable is not already set in the environment, so callers can still override.
#
# Notes for this platform:
#   - gfx1151 needs HSA_OVERRIDE_GFX_VERSION=11.5.1 for ROCm on recent kernels.
#   - Memory is unified (GTT); enable the GGML unified-memory path for ROCm.
#   - Vulkan (RADV) is often as fast or faster and avoids the ROCm KFD regressions,
#     so prefer the vulkan runtime here unless you specifically want ROCm.

: "${GFX_OVERRIDE:=11.5.1}"                 # -> HSA_OVERRIDE_GFX_VERSION for gfx1151
: "${ROCR_VISIBLE_DEVICES:=}"              # single GPU, no pinning needed
: "${HIP_VISIBLE_DEVICES:=}"
: "${ENABLE_UMA:=1}"                        # unified memory -> GGML_CUDA_ENABLE_UNIFIED_MEMORY

# llama-server tuning defaults for unified memory.
# Vulkan tends to like larger context / smaller ubatch than ROCm here.
: "${CTX_SIZE:=131072}"
: "${UBATCH:=1024}"
: "${BATCH:=4096}"
: "${THREADS:=8}"
