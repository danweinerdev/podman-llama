# Machine profile: AMD Radeon AI PRO R9700 (gfx1201, RDNA4, ~31 GiB dedicated VRAM)
#
# Sourced by the runtime launchers (runtime/rocm/run-rocm.sh, runtime/vulkan/run-vulkan.sh)
# when MACHINE=r9700. Every value here is a shell-level default: it only takes effect
# if the variable is not already set in the environment, so callers can still override.
#
# Notes for this card:
#   - gfx1201 is natively supported on modern ROCm (>= 7.x); NO HSA override is needed.
#   - The host usually also exposes a small iGPU (gfx1036). llama.cpp ROCm can segfault
#     when it enumerates that iGPU, so we pin visibility to the discrete R9700.
#     Adjust the index if `rocminfo` lists the R9700 as something other than device 0.
#   - Dedicated VRAM (not unified), so UMA env vars are intentionally left unset.

: "${GFX_OVERRIDE:=}"                       # native gfx1201 -> no HSA_OVERRIDE_GFX_VERSION
: "${ROCR_VISIBLE_DEVICES:=0}"              # pin to the discrete R9700, hide the iGPU
: "${HIP_VISIBLE_DEVICES:=0}"
: "${ENABLE_UMA:=0}"                        # dedicated VRAM, no unified-memory hack

# llama-server tuning defaults for a 32 GiB discrete card.
: "${CTX_SIZE:=32768}"
: "${UBATCH:=2048}"
: "${BATCH:=8192}"
: "${THREADS:=8}"
